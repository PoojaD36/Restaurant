// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/database/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// Seed configuration
// Run: npm run seed

enum UserRole {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  MANAGER
  CHEF
  DELIVERY_AGENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id        Int     @id @default(autoincrement())
  firstName String
  lastName  String?

  email String @unique
  phone String @unique

  profileImage String?

  role   UserRole
  status UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  password    UserPassword?
  restaurants RestaurantUser[]
  outlets     OutletUser[]
  deliveredOrders Order[] @relation("DeliveryAgentOrders")
  preparedOrders Order[] @relation("OrderChef")

  @@map("users")
}

model UserPassword {
  id Int @id @default(autoincrement())

  userId Int @unique

  passwordHash String
  refreshTokenHash   String?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_passwords")
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
}

model Restaurant {
  id Int @id @default(autoincrement())

  name String
  slug String @unique

  logo        String?
  description String?

  status RestaurantStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  outlets Outlet[]
  users   RestaurantUser[]
  menus   Menu[]

  @@map("restaurants")
}

model RestaurantUser {
  id Int @id @default(autoincrement())

  restaurantId Int
  userId       Int

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([restaurantId, userId])
  @@index([userId])
  @@map("restaurant_users")
}

enum OutletStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

model Outlet {
  id Int @id @default(autoincrement())

  restaurantId Int

  name String

  phone String?

  email String?

  addressLine1 String
  addressLine2 String?

  city       String
  state      String
  country    String
  postalCode String

  latitude  Decimal @db.Decimal(65, 30)
  longitude Decimal @db.Decimal(65, 30)

  openingTime String?
  closingTime String?

  status OutletStatus @default(ACTIVE)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  users   OutletUser[]
  orders  Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@map("outlets")
}

model OutletUser {
  id Int @id @default(autoincrement())

  outletId Int
  userId   Int

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([outletId, userId])
  @@index([userId])
  @@map("outlet_users")
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model Customer {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String?

  email String? @unique
  phone String  @unique

  profileImage String?

  status CustomerStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  password  CustomerPassword?
  addresses CustomerAddress[]
  orders    Order[]
  carts     CustomerCart[]

  @@map("customers")
}

model CustomerPassword {
  id Int @id @default(autoincrement())

  customerId Int @unique

  passwordHash String
  refreshTokenHash   String?

  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_passwords")
}

model CustomerAddress {
  id Int @id @default(autoincrement())

  customerId Int

  label String
  name  String
  phone String

  addressLine1 String
  addressLine2 String?

  city       String
  state      String
  country    String
  postalCode String

  latitude  Decimal @db.Decimal(65, 30)
  longitude Decimal @db.Decimal(65, 30)

  isDefault Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@map("customer_addresses")
}

// Customer Cart models - Server-side cart storage for cross-device sync
model CustomerCart {
  id           Int       @id @default(autoincrement())
  customerId   Int
  outletId     Int
  outletName   String
  outletAddress String?

  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  items        CartItem[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([customerId, outletId])
  @@index([customerId])
  @@map("customer_carts")
}

model CartItem {
  id              Int          @id @default(autoincrement())
  cartId          Int
  menuItemId      Int
  name            String
  price           Decimal      @db.Decimal(10, 2)
  quantity        Int
  modifiers       Json

  cart            CustomerCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([cartId])
  @@map("cart_items")
}

// Menu models - Restaurant level with outlet-specific pricing
model Menu {
  id          Int     @id @default(autoincrement())
  restaurantId Int

  name        String
  description String?
  status      MenuStatus @default(ACTIVE)

  restaurant  Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories  MenuCategory[]
  outletPricing MenuItemOutletPricing[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([restaurantId])
  @@map("menus")
}

model MenuCategory {
  id           Int         @id @default(autoincrement())
  menuId       Int

  name         String
  displayOrder Int         @default(0)
  status       MenuStatus @default(ACTIVE)

  menu         Menu        @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([menuId])
  @@map("menu_categories")
}

model MenuItem {
  id             Int              @id @default(autoincrement())
  categoryId     Int

  name           String
  description    String?
  basePrice      Decimal          @db.Decimal(10, 2)
  imageUrl       String?
  isVegetarian   Boolean          @default(false)
  isSpicy        Boolean          @default(false)
  preparationTime Int?            // in minutes
  calories       Int?
  status         MenuItemStatus   @default(AVAILABLE)

  category       MenuCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifiers      ModifierGroup[]
  outletPricing  MenuItemOutletPricing[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@map("menu_items")
}

// Outlet-specific pricing for menu items
model MenuItemOutletPricing {
  id        Int      @id @default(autoincrement())
  menuId    Int
  itemId    Int
  outletId  Int

  price     Decimal  @db.Decimal(10, 2)
  available Boolean  @default(true)

  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([menuId, itemId, outletId])
  @@index([outletId])
  @@map("menu_item_outlet_pricing")
}

// Modifier groups (e.g., "Size", "Add-ons")
model ModifierGroup {
  id       Int          @id @default(autoincrement())
  itemId   Int

  name     String
  type     ModifierType @default(SINGLE) // SINGLE or MULTIPLE selection
  required Boolean      @default(false)
  minSelect Int         @default(0)
  maxSelect Int         @default(1)
  displayOrder Int      @default(0)

  item     MenuItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options  ModifierOption[]

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([itemId])
  @@map("modifier_groups")
}

// Individual modifier options (e.g., "Small", "Medium", "Large")
model ModifierOption {
  id             Int           @id @default(autoincrement())
  modifierGroupId Int

  name           String
  priceAdjustment Decimal     @default(0) @db.Decimal(10, 2)
  isDefault      Boolean      @default(false)
  displayOrder   Int          @default(0)

  modifierGroup  ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([modifierGroupId])
  @@map("modifier_options")
}

enum MenuStatus {
  ACTIVE
  INACTIVE
}

enum MenuItemStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ModifierType {
  SINGLE    // User can select only one option (e.g., Size)
  MULTIPLE  // User can select multiple options (e.g., Add-ons)
}

// Order models
enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Order {
  id Int @id @default(autoincrement())

  customerId Int
  outletId   Int

  status OrderStatus @default(PENDING)

  // Price breakdown
  subtotal    Decimal @db.Decimal(10, 2)
  deliveryFee Decimal @default(0) @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  // Delivery address snapshot (copied from CustomerAddress at time of order)
  deliveryAddressLabel String
  deliveryName        String
  deliveryPhone       String
  deliveryAddressLine1 String
  deliveryAddressLine2 String?
  deliveryCity        String
  deliveryState       String
  deliveryCountry      String
  deliveryPostalCode   String
  deliveryLatitude     Decimal
  deliveryLongitude    Decimal

  // Special instructions from customer
  specialInstructions String?

  // Estimated delivery time (in minutes)
  estimatedDeliveryTime Int?

  // Actual delivery tracking
  deliveryAgentId Int?
  deliveryAgent   User?   @relation("DeliveryAgentOrders", fields: [deliveryAgentId], references: [id])
  pickedUpAt      DateTime?
  deliveredAt     DateTime?

  // Chef assignment
  chefId      Int?
  chef        User?   @relation("OrderChef", fields: [chefId], references: [id])
  startedAt   DateTime? // When chef started preparing
  completedAt DateTime? // When chef marked ready

  payment Payment?

  items OrderItem[]

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  outlet   Outlet   @relation(fields: [outletId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([outletId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id       Int @id @default(autoincrement())
  orderId  Int

  // Snapshot of menu item at time of order
  menuItemId Int
  name       String
  price      Decimal @db.Decimal(10, 2)
  quantity   Int

  // Modifiers snapshot (stored as JSON)
  modifiers Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id      Int @id @default(autoincrement())
  orderId Int @unique

  amount          Decimal @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String? // External payment ID (for card/UPI)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}
